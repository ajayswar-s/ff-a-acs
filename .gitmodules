[submodule "val_common"]
	path = val_common
	url = https://github.com/ARM-software/psa-acs-common-val.git
[submodule "linux-acs"]
	path = linux-acs
	url = https://gitlab.arm.com/linux-arm/linux-acs.git
[submodule "platform/common/src/edk2"]
	path = platform/common/src/edk2
	url = https://github.com/tianocore/edk2.git
	ignore = untracked
[submodule "platform/common/src/edk2-platforms"]
	path = platform/common/src/edk2-platforms
	url = https://github.com/tianocore/edk2-platforms.git
	ignore = untracked
